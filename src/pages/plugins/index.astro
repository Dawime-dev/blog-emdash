---
export const prerender = true;

import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentCard from '../../components/ContentCard.astro';

const items = await getCollection('plugins');
const sorted = items.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout
  title="Plugins EmDash"
  description="Tests et analyses des plugins disponibles pour EmDash : standard et natifs."
>
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Page header -->
      <div class="max-w-3xl mb-12">
        <h1 class="text-4xl sm:text-5xl font-extrabold text-text mb-4">
          Plugins
        </h1>
        <p class="text-lg text-text-muted leading-relaxed">
          Tests complets des plugins de l'ecosysteme EmDash. Decouvrez les plugins standard (sandboxes) et natifs pour etendre les fonctionnalites de votre CMS.
        </p>
      </div>

      <!-- Type legend -->
      <div class="flex flex-wrap gap-4 mb-10">
        <div class="flex items-center gap-2">
          <span class="inline-block w-3 h-3 rounded-full bg-accent-green"></span>
          <span class="text-sm text-text-muted">Standard (sandbox)</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="inline-block w-3 h-3 rounded-full bg-emdash"></span>
          <span class="text-sm text-text-muted">Natif</span>
        </div>
      </div>

      <!-- Plugins grid -->
      {sorted.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {sorted.map((item) => (
            <div class="relative">
              {/* Plugin type badge */}
              <div class="absolute top-4 right-4 z-10 flex items-center gap-2">
                <span
                  class:list={[
                    'text-xs font-semibold px-2.5 py-0.5 rounded-full',
                    item.data.pluginType === 'native'
                      ? 'bg-emdash/15 text-emdash'
                      : 'bg-accent-green/15 text-accent-green',
                  ]}
                >
                  {item.data.pluginType === 'native' ? 'Natif' : 'Standard'}
                </span>
                {item.data.rating && (
                  <span class="flex items-center gap-1 bg-surface/90 backdrop-blur-sm px-2 py-0.5 rounded-full border border-surface-lighter">
                    <svg class="w-3.5 h-3.5 text-emdash" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                    <span class="text-xs font-semibold text-text">{item.data.rating}/5</span>
                  </span>
                )}
              </div>
              <ContentCard
                title={item.data.title}
                description={item.data.description}
                href={`/plugins/${item.id}`}
                date={new Date(item.data.date)}
                category={item.data.pluginName}
                tags={item.data.tags}
                type="plugin"
              />
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-16 bg-surface-light/50 rounded-xl border border-surface-lighter/50">
          <p class="text-text-muted">Aucun test de plugin pour le moment. Revenez bientot !</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

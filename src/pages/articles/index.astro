---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentCard from '../../components/ContentCard.astro';

const items = await getCollection('articles');
const sorted = items.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const featured = sorted.filter((item) => item.data.featured);
const regular = sorted.filter((item) => !item.data.featured);
---

<BaseLayout
  title="Articles EmDash"
  description="Actualites, analyses et reflexions sur EmDash, le CMS open-source de Cloudflare."
>
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Page header -->
      <div class="max-w-3xl mb-12">
        <h1 class="text-4xl sm:text-5xl font-extrabold text-text mb-4">
          Articles
        </h1>
        <p class="text-lg text-text-muted leading-relaxed">
          Actualites, analyses et reflexions sur EmDash et l'ecosysteme du web moderne. Restez informe des dernieres evolutions du CMS.
        </p>
      </div>

      <!-- Featured articles -->
      {featured.length > 0 && (
        <div class="mb-16">
          <h2 class="text-xl font-bold text-text mb-6 flex items-center gap-2">
            <svg class="w-5 h-5 text-emdash" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
            Articles a la une
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {featured.map((item) => (
              <ContentCard
                title={item.data.title}
                description={item.data.description}
                href={`/articles/${item.id}`}
                date={new Date(item.data.date)}
                category={item.data.category}
                tags={item.data.tags}
                type="article"
              />
            ))}
          </div>
        </div>
      )}

      <!-- All articles -->
      <div>
        {featured.length > 0 && (
          <h2 class="text-xl font-bold text-text mb-6">Tous les articles</h2>
        )}
        {regular.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {regular.map((item) => (
              <ContentCard
                title={item.data.title}
                description={item.data.description}
                href={`/articles/${item.id}`}
                date={new Date(item.data.date)}
                category={item.data.category}
                tags={item.data.tags}
                type="article"
              />
            ))}
          </div>
        ) : (
          <div class="text-center py-16 bg-surface-light/50 rounded-xl border border-surface-lighter/50">
            <p class="text-text-muted">Aucun article pour le moment. Revenez bientot !</p>
          </div>
        )}
      </div>
    </div>
  </section>
</BaseLayout>

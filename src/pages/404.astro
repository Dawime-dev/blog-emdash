---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page non trouvee" description="La page que vous recherchez n'existe pas ou a ete deplacee.">
  <section class="py-32 text-center">
    <div class="max-w-2xl mx-auto px-4">
      <p class="text-8xl font-extrabold text-emdash mb-4">404</p>
      <h1 class="text-3xl font-bold text-text mb-4">Page non trouvee</h1>
      <p class="text-text-muted mb-10">
        La page que vous recherchez n'existe pas, a ete deplacee ou est temporairement indisponible.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center gap-2 px-6 py-3 bg-emdash hover:bg-emdash-dark text-white font-semibold rounded-xl transition-colors"
        >
          Retour a l'accueil
        </a>
        <a
          href="/tutoriels"
          class="inline-flex items-center gap-2 px-6 py-3 bg-surface-light hover:bg-surface-lighter text-text font-semibold rounded-xl border border-surface-lighter transition-colors"
        >
          Voir les tutoriels
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

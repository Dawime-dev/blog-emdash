---
---

<section class="py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-emdash/10 via-surface-light to-accent/5 border border-surface-lighter p-8 sm:p-12">
      <!-- Decorative elements -->
      <div class="absolute top-0 right-0 w-64 h-64 bg-emdash/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
      <div class="absolute bottom-0 left-0 w-48 h-48 bg-accent/5 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>

      <div class="relative max-w-2xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 text-emdash mb-4">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <span class="text-sm font-semibold uppercase tracking-wider">Newsletter</span>
        </div>

        <h2 class="text-2xl sm:text-3xl font-bold text-text mb-3">
          Rejoignez la communaute EmDash FR
        </h2>

        <p class="text-text-muted mb-8 max-w-lg mx-auto">
          Recevez chaque semaine les meilleurs tutoriels, les dernieres actualites
          et des ressources exclusives sur EmDash, directement dans votre boite mail.
        </p>

        <form class="newsletter-form flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
          <input
            type="email"
            name="email"
            placeholder="votre@email.com"
            required
            class="flex-1 px-4 py-3 rounded-xl bg-surface border border-surface-lighter text-text placeholder:text-text-muted/50 focus:outline-none focus:ring-2 focus:ring-emdash focus:border-transparent transition-shadow"
          />
          <button
            type="submit"
            class="px-6 py-3 bg-emdash hover:bg-emdash-dark text-white font-semibold rounded-xl transition-all duration-200 shadow-lg shadow-emdash/25 hover:shadow-xl hover:shadow-emdash/30 whitespace-nowrap"
          >
            S'inscrire
          </button>
        </form>
        <p class="newsletter-msg text-sm mt-4 hidden"></p>
        <p class="text-xs text-text-muted/60 mt-4">
          Pas de spam. Desabonnement en un clic.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.newsletter-form').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const f = e.currentTarget as HTMLFormElement;
      const msg = f.parentElement?.querySelector('.newsletter-msg') as HTMLElement;
      const email = new FormData(f).get('email') as string;
      const btn = f.querySelector('button') as HTMLButtonElement;

      btn.disabled = true;
      btn.textContent = '...';

      try {
        const res = await fetch('/api/newsletter', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        const data = await res.json();
        msg.textContent = data.message || data.error;
        msg.className = `newsletter-msg text-sm mt-4 ${res.ok ? 'text-accent-green' : 'text-red-400'}`;
        msg.classList.remove('hidden');
        if (res.ok) f.reset();
      } catch {
        msg.textContent = 'Erreur de connexion. Reessayez.';
        msg.className = 'newsletter-msg text-sm mt-4 text-red-400';
        msg.classList.remove('hidden');
      }

      btn.disabled = false;
      btn.textContent = "S'inscrire";
    });
  });
</script>

---
const year = new Date().getFullYear()

const columns = [
  {
    title: 'A propos',
    links: [
      { label: 'A propos du site', href: '/a-propos' },
      { label: 'GitHub EmDash', href: 'https://github.com/emdash-cms/emdash', external: true },
    ],
  },
  {
    title: 'Contenu',
    links: [
      { label: 'Tutoriels', href: '/tutoriels' },
      { label: 'Guides', href: '/guides' },
      { label: 'Articles', href: '/articles' },
      { label: 'Dossiers', href: '/dossiers' },
    ],
  },
  {
    title: 'Communaute',
    links: [
      { label: 'GitHub EmDash', href: 'https://github.com/emdash-cms/emdash', external: true },
      { label: 'Discord', href: 'https://discord.gg/emdash', external: true },
      { label: 'Twitter / X', href: 'https://x.com/emdashcms', external: true },
      { label: 'Plugins EmDash', href: '/plugins' },
    ],
  },
  {
    title: 'Liens utiles',
    links: [
      { label: 'Documentation officielle', href: 'https://docs.emdashcms.com', external: true },
      { label: 'Cloudflare', href: 'https://www.cloudflare.com', external: true },
      { label: 'Astro', href: 'https://astro.build', external: true },
      { label: 'Themes EmDash', href: '/themes' },
    ],
  },
]
---

<footer class="bg-surface-light border-t border-surface-lighter">
  <!-- Newsletter -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 border-b border-surface-lighter">
    <div class="max-w-2xl mx-auto text-center">
      <h3 class="text-xl font-bold text-text mb-2">Restez informe</h3>
      <p class="text-text-muted mb-6">
        Recevez les derniers tutoriels et actualites EmDash directement dans votre boite mail.
      </p>
      <form class="newsletter-form flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input
          type="email"
          name="email"
          placeholder="votre@email.com"
          required
          class="flex-1 px-4 py-2.5 rounded-lg bg-surface border border-surface-lighter text-text placeholder:text-text-muted/50 focus:outline-none focus:ring-2 focus:ring-emdash focus:border-transparent"
        />
        <button
          type="submit"
          class="px-6 py-2.5 bg-emdash hover:bg-emdash-dark text-white font-semibold rounded-lg transition-colors whitespace-nowrap"
        >
          S'inscrire
        </button>
      </form>
      <p class="newsletter-msg text-sm mt-3 hidden"></p>
    </div>
  </div>

  <!-- Links grid -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      {columns.map((col) => (
        <div>
          <h4 class="font-semibold text-text mb-4">{col.title}</h4>
          <ul class="space-y-2.5">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-text-muted hover:text-emdash transition-colors inline-flex items-center gap-1"
                  {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {link.label}
                  {link.external && (
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-surface-lighter">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2">
        <span class="text-xl font-extrabold text-emdash">&mdash;</span>
        <span class="font-bold text-text">EmDash <span class="text-emdash">FR</span></span>
      </div>
      <p class="text-sm text-text-muted">
        &copy; {year} EmDash FR. Contenu sous licence CC BY-SA 4.0. Site non affilie a Cloudflare.
      </p>
    </div>
  </div>
</footer>
